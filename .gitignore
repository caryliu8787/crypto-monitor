reports/*.md
reports/latest-alert.txt

# Sensitive config (contains bot tokens)
config/output.json

# Brainstorm session files
.superpowers/

# Claude local settings
.claude/

# OS files
.DS_Store

# Editor files
*.swp
*.swo
*~
