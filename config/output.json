{
  "_comment": "输出格式配置。每种格式可独立开关。",

  "formats": {
    "markdown": {
      "enabled": true,
      "path": "reports/",
      "filename_pattern": "YYYY-MM-DD_{session}.md",
      "session_labels": {
        "morning": "08:00 UTC+8",
        "evening": "20:00 UTC+8"
      }
    },
    "html_dashboard": {
      "enabled": true,
      "path": "reports/",
      "filename_pattern": "YYYY-MM-DD_{session}.html",
      "template": "templates/dashboard.html"
    },
    "json_snapshot": {
      "enabled": true,
      "latest_path": "data/latest.json",
      "history_path": "data/history/",
      "history_retention_days": 30
    },
    "alert_summary": {
      "enabled": true,
      "path": "reports/latest-alert.txt",
      "format": "single_line",
      "example": "2026-04-03 08:00 | BTC $84,500 (-1.2%) | FGI 45 | No critical alerts"
    },
    "telegram": {
      "enabled": true,
      "bot_token": "",
      "chat_id": "",
      "send_screenshot": false,
      "send_summary": true
    },
    "notion": {
      "enabled": false,
      "database_id": "",
      "parent_page_id": "",
      "database_name": "Crypto Daily Reports",
      "properties": {
        "Date": "date",
        "Session": "select",
        "BTC Price": "number",
        "Market Phase": "select",
        "Alerts": "multi_select",
        "Overall Score": "number"
      }
    }
  }
}
